# Courtside — aggregate .env.example. Copy to .env at the repo root and fill in.
# Each service also has its own package-scoped .env.example; this is the one-stop
# version for a fresh clone.

# ────────────────────────────────────────────────────────────────
# mcp-server — NBA MCP tool server (Tier 1)
# ────────────────────────────────────────────────────────────────
# Free tier from https://app.balldontlie.io/ — used for teams / players / games only.
BALLDONTLIE_API_KEY=
# Port the Streamable HTTP MCP transport listens on.
MCP_PORT=3001
# pino log level (trace|debug|info|warn|error)
LOG_LEVEL=info

# ────────────────────────────────────────────────────────────────
# runtime — LangGraph agent runtime (Tier 2)
# ────────────────────────────────────────────────────────────────
# Where the runtime finds the MCP server over Streamable HTTP.
MCP_SERVER_URL=http://localhost:3001/mcp
# Primary LLM (may currently return limit:0 — see docs/adr/0001).
GEMINI_API_KEY=
# Fallback LLM.
GROQ_API_KEY=
# Prisma datasource. SQLite for dev, Neon Postgres URL for prod.
DATABASE_URL=file:./dev.db
# HTTP port for the runtime API.
PORT=3002
# CORS origin allow-list for the client.
CLIENT_ORIGIN=http://localhost:5173

# ────────────────────────────────────────────────────────────────
# client — React app (Tier 3)
# ────────────────────────────────────────────────────────────────
# Base URL the browser hits for /agent/run, /jobs, /runs, /health.
VITE_RUNTIME_URL=http://localhost:3002
