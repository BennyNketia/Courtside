# mcp-server — NBA MCP tool server (Tier 1)

# Free tier from https://app.balldontlie.io/ — used for teams / players / games only.
# The paid endpoints (season_averages, stats) are NOT used; see docs/adr/0001.
BALLDONTLIE_API_KEY=

# Port the Streamable HTTP MCP transport listens on.
MCP_PORT=3001

# pino-style log level: trace | debug | info | warn | error
LOG_LEVEL=info
