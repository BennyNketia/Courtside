{
  "name": "@courtside/mcp-server",
  "private": true,
  "version": "0.0.0",
  "description": "Courtside Tier 1 — standalone NBA MCP tool server over Streamable HTTP.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts' 'scripts/**/*.ts'",
    "typecheck": "tsc -p tsconfig.check.json",
    "test": "vitest run",
    "refresh-seeds": "tsx scripts/refresh-seeds.ts"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.10",
    "@types/supertest": "^7.2.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  }
}
