# runtime — LangGraph agent runtime
MCP_SERVER_URL=http://localhost:3001/mcp
MCP_CONNECT_TIMEOUT_MS=5000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
DATABASE_URL=file:./dev.db
PORT=3002
CLIENT_ORIGIN=http://localhost:5173
# Agent runtime knobs. Defaults come from SPEC — override only if you know why.
AGENT_MAX_ITERATIONS=8
AGENT_TIMEOUT_MS=60000
# Per-IP rate limit on /agent/run. Keep this tight — protects free-tier LLM quota.
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000
LOG_LEVEL=info
